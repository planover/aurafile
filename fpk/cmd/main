#!/bin/bash
# Aurafile (光匣) Docker 应用生命周期脚本
# Docker 应用的启停由 fnOS 应用中心通过 compose 管理，
# cmd/main 仅负责状态检查。

FILE_PATH="${TRIM_APPDEST}/docker/docker-compose.yaml"

is_docker_running() {
    if [ -f "$FILE_PATH" ]; then
        local DOCKER_NAME
        DOCKER_NAME=$(grep "container_name" "$FILE_PATH" | awk -F':' '{print $2}' | xargs 2>/dev/null)
        if [ -n "$DOCKER_NAME" ]; then
            docker inspect "$DOCKER_NAME" 2>/dev/null | grep -q '"Status": "running"' && return 0
        fi
    fi
    return 1
}

case "$1" in
    start)
        # Docker 应用由应用中心通过 compose 管理启动，无需额外操作
        exit 0
        ;;
    stop)
        # Docker 应用由应用中心通过 compose 管理停止，无需额外操作
        exit 0
        ;;
    status)
        # 检查容器运行状态：0=运行中, 3=未运行
        if is_docker_running; then
            exit 0
        else
            exit 3
        fi
        ;;
    *)
        exit 1
        ;;
esac
