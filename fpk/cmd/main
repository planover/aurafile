#!/bin/bash
# Aurafile (光匣) Docker 应用生命周期脚本
# Docker 应用的启停由 fnOS 应用中心通过 compose 管理，
# cmd/main 仅负责状态检查。

FILE_PATH="${TRIM_APPDEST}/docker/docker-compose.yaml"

is_docker_running() {
    if [ -f "$FILE_PATH" ]; then
        local DOCKER_NAME
        DOCKER_NAME=$(grep "container_name" "$FILE_PATH" | awk -F':' '{print $2}' | xargs 2>/dev/null)
        if [ -n "$DOCKER_NAME" ]; then
            docker inspect "$DOCKER_NAME" 2>/dev/null | grep -q '"Status": "running"' && return 0
        fi
    fi
    return 1
}

case "$1" in
    start)
        # Docker 应用由应用中心通过 compose 管理启动，无需额外操作
        exit 0
        ;;
    stop)
        # Docker 应用由应用中心通过 compose 管理停止，无需额外操作
        exit 0
        ;;
    status)
        # fnOS 生命周期脚本执行环境可能无 docker socket 权限，
        # 直接用 docker inspect 会永远判定“未运行”→ 应用商店显示“停用”。
        # 改为探测已发布到宿主机的服务端口（compose 已把 8018 映射到 host），
        # 容器真实在跑即可探测成功。0=运行中, 3=未运行。
        if wget -qO- --timeout=3 "http://localhost:8018/api/health" >/dev/null 2>&1; then
            exit 0
        fi
        if curl -fsS --max-time 3 "http://localhost:8018/api/health" >/dev/null 2>&1; then
            exit 0
        fi
        # 兜底：保留原 docker inspect 探测（极端环境仍可用）
        if is_docker_running; then
            exit 0
        fi
        exit 3
        ;;
    *)
        exit 1
        ;;
esac
